{% extends 'base.html.twig' %}
{% block title %}Connexion{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Connexion</h4>
                </div>
                <div class="card-body p-4">

                    {# Connexion classique #}
                    <h6 class="text-muted mb-3">Avec mot de passe</h6>
                    {% if app.request.query.get('error') %}
                        <div class="alert alert-danger py-2 small">Identifiants incorrects.</div>
                    {% endif %}
                    <form method="post" action="{{ path('app_login') }}">
                        <div class="mb-3">
                            <input type="text" name="_username" class="form-control"
                                   placeholder="Nom d'utilisateur" autocomplete="username" required autofocus>
                        </div>
                        <div class="mb-3">
                            <input type="password" name="_password" class="form-control"
                                   placeholder="Mot de passe" autocomplete="current-password" required>
                        </div>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        <button type="submit" class="btn btn-dark w-100">Se connecter</button>
                    </form>

                    <div class="d-flex align-items-center my-3">
                        <hr class="flex-grow-1"><span class="px-2 text-muted small">ou</span><hr class="flex-grow-1">
                    </div>

                    {# Connexion Passkey #}
                    <h6 class="text-muted mb-2">Avec passkey (biométrie)</h6>
                    <input type="text" id="passkey-username" class="form-control mb-2"
                           placeholder="Nom d'utilisateur (optionnel)" autocomplete="username">
                    <button id="btn-passkey-login" class="btn btn-primary w-100">
                        Se connecter avec une passkey
                    </button>

                    <div id="passkey-msg" class="mt-3" style="display:none"></div>

                    <hr>
                    <p class="text-center mb-0 small">
                        Pas de compte ?
                        <a href="{{ path('passkey_register_page') }}">Créer un compte</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="{{ asset('js/auth.js') }}"></script>
<script>
document.getElementById('btn-passkey-login').addEventListener('click', async () => {
    const username = document.getElementById('passkey-username').value.trim();
    const btn      = document.getElementById('btn-passkey-login');
    const msg      = document.getElementById('passkey-msg');

    btn.disabled    = true;
    btn.textContent = 'Authentification en cours…';
    msg.style.display = 'none';

    try {
        const result = await loginWithPasskey(username);
        msg.className   = 'alert alert-success';
        msg.textContent = result.message + ' Redirection…';
        msg.style.display = 'block';
        setTimeout(() => window.location.href = '/', 1000);
    } catch (err) {
        msg.className   = 'alert alert-danger';
        msg.textContent = err.message;
        msg.style.display = 'block';
        btn.disabled    = false;
        btn.textContent = 'Se connecter avec une passkey';
    }
});
</script>
{% endblock %}