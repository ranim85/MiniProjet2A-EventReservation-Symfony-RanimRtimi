{% extends 'admin/base.html.twig' %}

{% block title %}Réservations pour {{ event.title }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Réservations : <span class="text-gradient-primary">{{ event.title }}</span></h1>
        <a href="{{ path('admin_event_index') }}" class="btn btn-outline-glass btn-sm">Retour aux événements</a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom Complet</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Date de Réservation</th>
                </tr>
            </thead>
            <tbody>
            {% for res in reservations %}
                <tr>
                    <td>#{{ res.id }}</td>
                    <td class="fw-bold">{{ res.name }}</td>
                    <td><a href="mailto:{{ res.email }}" class="text-info text-decoration-none">{{ res.email }}</a></td>
                    <td>{{ res.phone }}</td>
                    <td>{{ res.createdAt ? res.createdAt|date('d/m/Y H:i') : '' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4 text-secondary">Aucune réservation pour cet événement actuellement.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
