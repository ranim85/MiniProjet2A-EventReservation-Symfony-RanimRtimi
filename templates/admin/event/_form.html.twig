{{ form_start(form) }}
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_row(form.title, {'attr': {'class': 'form-control form-glass'}}) }}
        </div>
        <div class="col-md-6 mb-3">
            {{ form_row(form.location, {'attr': {'class': 'form-control form-glass'}}) }}
        </div>
        <div class="col-md-4 mb-3">
            {{ form_row(form.date, {'attr': {'class': 'form-control form-glass'}}) }}
        </div>
        <div class="col-md-4 mb-3">
            {{ form_row(form.seats, {'attr': {'class': 'form-control form-glass'}}) }}
        </div>
        <div class="col-md-4 mb-3">
            {{ form_row(form.image, {'attr': {'class': 'form-control form-glass'}}) }}
        </div>
        <div class="col-12 mb-4">
            {{ form_row(form.description, {'attr': {'class': 'form-control form-glass', 'rows': 4}}) }}
        </div>
        <div class="col-12 text-end">
            <button class="btn btn-glass">{{ button_label|default('Enregistrer') }}</button>
        </div>
    </div>
{{ form_end(form) }}
