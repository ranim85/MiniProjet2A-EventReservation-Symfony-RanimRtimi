{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="row gx-5">
    <div class="col-lg-7 mb-4">
        <div class="glass-card h-100 p-1">
            <img src="{{ event.image|default('https://images.unsplash.com/photo-1459749411175-04bf5292ceea?q=80&w=1000&auto=format&fit=crop') }}" alt="{{ event.title }}" style="height: 400px; border-radius: 12px; object-fit: cover; width: 100%;">
        </div>
    </div>
    <div class="col-lg-5">
        <div class="p-4 glass-card h-100 d-flex flex-column justify-content-center">
            <div class="mb-4">
                <span class="badge mb-3" style="background: rgba(121, 40, 202, 0.2); color: #c471ed; font-size: 0.9em;">
                    <i class="bi bi-calendar-event me-2"></i>{{ event.date|date('d F Y à H:i') }}
                </span>
                <h1 class="display-5 fw-bold text-white mb-4">{{ event.title }}</h1>
            </div>

            <div class="d-flex align-items-center mb-4">
                <div class="me-4">
                    <p class="text-secondary small mb-1">Localisation</p>
                    <p class="fw-bold mb-0">{{ event.location }}</p>
                </div>
                <div>
                    <p class="text-secondary small mb-1">Places Disponibles</p>
                    <p class="fw-bold text-gradient-primary mb-0 fs-5">{{ event.seats }}</p>
                </div>
            </div>

            <hr style="border-color: rgba(255, 255, 255, 0.1);">

            <h4 class="mb-3 mt-3">À propos</h4>
            <p class="text-secondary lh-lg mb-5">{{ event.description }}</p>

            <a href="{{ path('app_event_reserve', {'id': event.id}) }}" class="btn btn-glass btn-lg mt-auto text-center">
                Réserver ma place maintenant
            </a>
            <a href="{{ path('app_home') }}" class="btn btn-outline-glass btn-block mt-3 w-100 text-center">Retour aux événements</a>
        </div>
    </div>
</div>
{% endblock %}
