{% extends 'base.html.twig' %}

{% block title %}Tous les événements{% endblock %}

{% block body %}
<div class="hero-section text-center">
    <h1 class="display-3 fw-bold mb-4">Découvrez des <span class="text-gradient">Expériences</span></h1>
    <p class="lead text-secondary mb-5">Réservez vos places pour les événements les plus attendus de l'année.</p>
</div>

<div class="grid-events">
    {% for event in events %}
        <div class="glass-card">
            <img src="{{ event.image|default('https://images.unsplash.com/photo-1459749411175-04bf5292ceea?q=80&w=1000&auto=format&fit=crop') }}" alt="{{ event.title }}">
            <div class="p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge" style="background: rgba(121, 40, 202, 0.2); color: #c471ed;">{{ event.date|date('d M Y') }}</span>
                    <span class="text-secondary small"><i class="bi bi-geo-alt"></i> {{ event.location }}</span>
                </div>
                <h3 class="card-title h5 mb-3">{{ event.title }}</h3>
                <p class="card-text small mb-4">{{ event.description|slice(0, 100) ~ '...' }}</p>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="text-gradient-primary fw-bold">{{ event.seats }} places</span>
                    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-glass btn-sm">Détails</a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12 text-center py-5">
            <h3 class="text-secondary">Aucun événement prévu pour le moment.</h3>
        </div>
    {% endfor %}
</div>
{% endblock %}