{% extends 'base.html.twig' %}
{% block title %}Événements disponibles{% endblock %}
{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">Événements à venir</h1>
    <div class="row">
    {% for event in events %}
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                {% if event.image %}
                    <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" style="height:180px;object-fit:cover">
                {% endif %}
                <div class="card-body">
                    <h5 class="card-title">{{ event.title }}</h5>
                    <p class="card-text text-muted"><small> {{ event.date|date('d/m/Y H:i') }} —  {{ event.location }}</small></p>
                    <p class="card-text">{{ event.description|slice(0, 100) }}...</p>
                    <p><span class="badge bg-info">{{ event.seats }} places</span></p>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-outline-primary btn-sm">Voir détail</a>
                    <a href="{{ path('app_event_reserve', {id: event.id}) }}" class="btn btn-primary btn-sm">Réserver</a>
                </div>
            </div>
        </div>
    {% else %}
        <p>Aucun événement disponible.</p>
    {% endfor %}
    </div>
</div>
{% endblock %}