{% extends 'base.html.twig' %}

{% block title %}Confirmation de Réservation{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 text-center mt-5">
        <div class="glass-card p-5 animate-fade-in shadow-lg">
            
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem; text-shadow: 0 0 20px rgba(40, 167, 69, 0.5);"></i>
            </div>
            
            <h1 class="display-5 text-white mb-3">Réservation Confirmée !</h1>
            
            <p class="lead text-secondary mb-5">
                Félicitations <strong class="text-white">{{ reservation.name }}</strong>, vous avez réservé votre place pour l'événement :<br>
                <span class="text-gradient-primary fs-4 fw-bold mt-2 d-block">{{ event.title }}</span>
            </p>
            
            <div class="d-flex justify-content-between mb-4 text-start border-top border-bottom py-3" style="border-color: var(--card-border) !important;">
                <div>
                    <small class="text-secondary d-block">Date</small>
                    <span class="fw-bold">{{ event.date|date('d/m/Y') }}</span>
                </div>
                <div>
                    <small class="text-secondary d-block">Lieu</small>
                    <span class="fw-bold">{{ event.location }}</span>
                </div>
            </div>

            <a href="{{ path('app_home') }}" class="btn btn-glass btn-lg w-100 mt-4">Retour à l'accueil</a>
        </div>
    </div>
</div>
{% endblock %}